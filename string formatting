def print_formatted(number):
    # your code goes here
    # Calculate the width of the binary representation of 'number'
    # bin(number) returns '0b10001', so we slice from index 2
    width = len(bin(number)[2:])

    for i in range(1, number + 1):
        # Generate the strings for each base
        dec = str(i)
        octal = oct(i)[2:]
        hex_val = hex(i)[2:].upper()
        binary = bin(i)[2:]
        
        # Print each value right-justified to the calculated width
        print(f"{dec.rjust(width)} {octal.rjust(width)} {hex_val.rjust(width)} {binary.rjust(width)}")

